---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contattaci — NexLudica APS" description="Contatta NexLudica per informazioni, collaborazioni o per diventare socio.">
  <section class="nx-hero-pattern px-4 pb-16 pt-28 text-center">
    <h1 class="text-4xl font-extrabold text-nx-dark md:text-5xl" style="font-family: var(--font-display);">
      Contattaci
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-nx-gray-dark">
      Hai domande, proposte o vuoi collaborare? Siamo qui per te.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-2">
      <!-- Info contatto -->
      <div class="space-y-8">
        <div>
          <h2 class="text-xl font-bold text-nx-dark">Scrivici</h2>
          <p class="mt-2 text-nx-gray-dark">
            Per informazioni generali, collaborazioni o stampa:
          </p>
          <a
            href="mailto:info@nexludica.org"
            class="mt-2 inline-block text-lg font-semibold text-nx-cyan no-underline hover:underline"
          >
            info@nexludica.org
          </a>
          <p class="mt-4 text-nx-gray-dark">
            Per contattare direttamente il presidente:
          </p>
          <a
            href="mailto:vittorio.guerrieri@nexludica.org"
            class="mt-2 inline-block text-base font-medium text-nx-cyan no-underline hover:underline"
          >
            vittorio.guerrieri@nexludica.org
          </a>
        </div>

        <div>
          <h2 class="text-xl font-bold text-nx-dark">Dove siamo</h2>
          <p class="mt-2 text-nx-gray-dark">
            Sede legale:<br />
            Vico Barnabiti 10<br />
            16124 Genova (GE)
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-nx-dark">Seguici</h2>
          <p class="mt-2 text-nx-gray-dark">
            Resta aggiornato sulle nostre attività seguendoci sui social.
          </p>
          <div class="mt-3 flex gap-4">
            <a
              href="https://www.instagram.com/nexludica"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-nx-cyan-light text-nx-cyan transition hover:bg-nx-cyan hover:text-white no-underline"
              aria-label="Instagram"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a
              href="https://www.facebook.com/nexludica"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-nx-cyan-light text-nx-cyan transition hover:bg-nx-cyan hover:text-white no-underline"
              aria-label="Facebook"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Form contatto -->
      <div>
        <form id="contact-form" class="space-y-5 rounded-xl border border-nx-gray-light/20 bg-white p-8 shadow-sm">
          <!-- Honeypot anti-bot: invisibile agli umani, i bot tendono a riempirlo -->
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
            aria-hidden="true"
          />
          <div>
            <label for="name" class="block text-sm font-medium text-nx-dark">Nome</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-nx-dark">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
            />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-nx-dark">Oggetto</label>
            <select
              id="subject"
              name="subject"
              class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
            >
              <option value="info">Informazioni generali</option>
              <option value="collaborazione">Proposta di collaborazione</option>
              <option value="socio">Diventare socio</option>
              <option value="altro">Altro</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-nx-dark">Messaggio</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-nx-cyan px-6 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-nx-blue"
          >
            Invia messaggio
          </button>
          <p class="text-xs text-nx-gray-dark">
            I tuoi dati saranno trattati nel rispetto della
            <a href="/privacy-policy" class="text-nx-cyan hover:underline">Privacy Policy</a>.
          </p>
          <div id="contact-result" class="hidden rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-800">
            ✓ Messaggio inviato. Ti rispondiamo al più presto.
          </div>
          <div id="contact-error" class="hidden rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800"></div>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById("contact-form");
      const ok = document.getElementById("contact-result");
      const err = document.getElementById("contact-error");
      if (!form) return;
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        ok.classList.add("hidden");
        err.classList.add("hidden");
        const fd = new FormData(form);
        const body = Object.fromEntries(fd.entries());
        const btn = form.querySelector("button[type=submit]");
        btn.disabled = true;
        const oldText = btn.textContent;
        btn.textContent = "Invio in corso...";
        try {
          const res = await fetch("/api/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) {
            err.textContent = data.error || "Errore durante l'invio.";
            err.classList.remove("hidden");
          } else {
            ok.classList.remove("hidden");
            form.reset();
          }
        } catch (e) {
          err.textContent = "Errore di rete. Riprova.";
          err.classList.remove("hidden");
        } finally {
          btn.disabled = false;
          btn.textContent = oldText;
        }
      });
    })();
  </script>
</BaseLayout>
