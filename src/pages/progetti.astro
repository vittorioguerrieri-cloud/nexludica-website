---
import BaseLayout from "../layouts/BaseLayout.astro";

const progetti = [
  {
    title: "Giochi al Pesto",
    description: "Serate di gioco da tavolo e gioco di ruolo gratuite e aperte a tutti, in diverse sedi della città metropolitana di Genova. Il progetto bandiera di NexLudica per l'inclusione sociale attraverso il gioco.",
    status: "Attivo",
    link: "https://giochialpesto.it",
  },
  {
    title: "Formazione educatori",
    description: "Percorsi formativi per educatori, insegnanti e animatori sull'uso del gioco come strumento pedagogico e di inclusione.",
    status: "Attivo",
  },
  {
    title: "Ricerca impatto sociale",
    description: "Studio e valutazione dell'impatto sociale delle attività ludiche sulla comunità, con pubblicazione di report e articoli scientifici.",
    status: "In corso",
  },
];
---

<BaseLayout title="Progetti — NexLudica APS" description="I progetti di NexLudica: eventi ludici, formazione, ricerca e inclusione sociale attraverso il gioco.">
  <section class="nx-hero-pattern px-4 pb-16 pt-28 text-center">
    <h1 class="text-4xl font-extrabold text-nx-dark md:text-5xl" style="font-family: var(--font-display);">
      I nostri progetti
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-nx-gray-dark">
      Dall'organizzazione di eventi alla ricerca scientifica: ecco come portiamo avanti la nostra missione.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="space-y-8">
      {progetti.map((progetto) => (
        <article class="rounded-xl border border-nx-gray-light/20 bg-white p-8 shadow-sm transition hover:shadow-md">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <h2 class="text-2xl font-bold text-nx-dark">{progetto.title}</h2>
            <span class={`rounded-full px-3 py-1 text-xs font-semibold ${
              progetto.status === "Attivo"
                ? "bg-emerald-100 text-emerald-700"
                : "bg-amber-100 text-amber-700"
            }`}>
              {progetto.status}
            </span>
          </div>
          <p class="mt-4 text-nx-gray-dark leading-relaxed">{progetto.description}</p>
          {progetto.link && (
            <a
              href={progetto.link}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-nx-cyan no-underline hover:underline"
            >
              Visita il sito &rarr;
            </a>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
