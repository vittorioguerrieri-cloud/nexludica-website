---
import BaseLayout from "../layouts/BaseLayout.astro";

const team = [
  { name: "Vittorio Guerrieri", skills: "Psicometria · Game design · Lavoro sociale" },
  { name: "Raluca Fulgu", skills: "Psicologia sociale · Ricerca · Inclusione" },
  { name: "Mattia Drago", skills: "Gioco da tavolo · Imprenditoria · Fitness" },
  { name: "Marco Monteverde", skills: "Game design · Informatica · Comunicazione" },
  { name: "Simone Glogowschek", skills: "Game design · Matematica · Insegnamento" },
  { name: "Camilla Fadda", skills: "Concept art · Social · Storytelling" },
  { name: "Maria Pulinas", skills: "Impegno sociale · Carcere · Linguistica" },
];
---

<BaseLayout title="Chi siamo — NexLudica APS" description="NexLudica APS: associazione che usa il gioco da tavolo per ricerca, inclusione e formazione. Mission, valori e team.">
  <section class="nx-hero-pattern px-4 pb-16 pt-28 text-center">
    <h1 class="text-4xl font-extrabold text-nx-dark md:text-5xl" style="font-family: var(--font-display);">
      Chi siamo
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-nx-gray-dark">
      Un gruppo di appassionati di gioco da tavolo, ricercatori, artisti e game designer
      che credono nel potere formativo, sociale e motivazionale del gioco.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-16">
    <div class="space-y-12">
      <div>
        <h2 class="text-2xl font-bold text-nx-dark">La nostra missione</h2>
        <p class="mt-4 text-nx-gray-dark leading-relaxed">
          Giocare è molto più che un passatempo: è un'esperienza che coinvolge mente e
          relazioni. NexLudica nasce per esplorare il potenziale trasformativo del gioco
          da tavolo come strumento per promuovere il benessere psicologico, favorire
          l'inclusione sociale e sviluppare competenze trasversali.
        </p>
        <p class="mt-4 text-nx-gray-dark leading-relaxed">
          Il nostro approccio combina <strong class="text-nx-dark">ricerca scientifica</strong>,
          <strong class="text-nx-dark">sperimentazione sul campo</strong> e
          <strong class="text-nx-dark">progettazione partecipata</strong>: il gioco viene
          concepito come strumento per attivare risorse, creare connessioni e immaginare
          nuove possibilità nei contesti sociali.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-nx-dark">I tre pilastri</h2>
        <ul class="mt-6 space-y-5">
          <li class="flex items-start gap-4">
            <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-nx-cyan-light text-sm font-bold text-nx-cyan">G</span>
            <div>
              <strong class="text-nx-dark">Game</strong>
              <p class="mt-1 text-nx-gray-dark">
                Il gioco da tavolo è il nostro linguaggio e il nostro strumento.
                Crediamo nel suo potere di trasformare, motivare e connettere chi gioca.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-nx-cyan-light text-sm font-bold text-nx-cyan">R</span>
            <div>
              <strong class="text-nx-dark">Research</strong>
              <p class="mt-1 text-nx-gray-dark">
                Facciamo ricerca sul gioco da tavolo e con il gioco da tavolo.
                Lo usiamo per esplorare il comportamento umano, la tecnologia e
                le dinamiche sociali.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-nx-cyan-light text-sm font-bold text-nx-cyan">I</span>
            <div>
              <strong class="text-nx-dark">Inclusion</strong>
              <p class="mt-1 text-nx-gray-dark">
                Abbiamo l'obiettivo di creare spazi di crescita e connessione.
                Ognuno in NexLudica ha occasione di contribuire e sentirsi parte
                di qualcosa più grande.
              </p>
            </div>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-nx-dark">Il team</h2>
        <p class="mt-4 text-nx-gray-dark leading-relaxed">
          Soci e collaboratori di NexLudica con le rispettive aree di competenza.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {team.map((p) => (
            <div class="rounded-lg border border-nx-gray-light/20 bg-white p-4">
              <p class="text-base font-semibold text-nx-dark">{p.name}</p>
              <p class="mt-1 text-xs text-nx-gray-dark">{p.skills}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-nx-dark">L'associazione</h2>
        <p class="mt-4 text-nx-gray-dark leading-relaxed">
          NexLudica è un'Associazione di Promozione Sociale (APS) con sede a Genova.
          Operiamo sul territorio nazionale attraverso progetti, eventi e ricerca.
        </p>
        <div class="mt-6 rounded-lg border border-nx-gray-light/20 bg-nx-off-white p-6">
          <dl class="grid gap-4 sm:grid-cols-2">
            <div>
              <dt class="text-xs font-semibold uppercase text-nx-gray-dark">Codice fiscale</dt>
              <dd class="mt-1 text-sm font-medium text-nx-dark">95252550108</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-nx-gray-dark">Sede legale</dt>
              <dd class="mt-1 text-sm font-medium text-nx-dark">Vico Barnabiti 10, Genova</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-nx-gray-dark">Email</dt>
              <dd class="mt-1 text-sm font-medium text-nx-dark">info@nexludica.org</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold uppercase text-nx-gray-dark">Sito web</dt>
              <dd class="mt-1 text-sm font-medium text-nx-dark">nexludica.org</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
