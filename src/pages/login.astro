---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getUser } from "../server/guards";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
const errorMessages: Record<string, string> = {
  "missing-token": "Link non valido.",
  "invalid-token": "Link scaduto o già usato. Richiedi un nuovo accesso.",
  backend: "Servizio temporaneamente non disponibile.",
};
const errorMsg = error ? errorMessages[error] ?? "Errore non riconosciuto." : null;

// Se l'utente e' gia' loggato, redirect.
const user = await getUser(Astro);
if (user) {
  return Astro.redirect("/area-soci");
}
---

<BaseLayout title="Accedi — NexLudica APS" description="Accesso area soci NexLudica.">
  <section class="bg-nx-off-white px-4 pb-16 pt-28">
    <div class="mx-auto max-w-md">
      <p class="text-sm font-bold uppercase tracking-[0.3em] text-nx-cyan">Area Soci</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-nx-dark sm:text-5xl" style="font-family: var(--font-display);">
        Accedi
      </h1>

      {errorMsg && (
        <div class="mt-6 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800">
          {errorMsg}
        </div>
      )}

      <!-- Tab switcher -->
      <div class="mt-8 grid grid-cols-2 rounded-lg bg-nx-gray-light/20 p-1 text-sm">
        <button id="tab-magic" class="rounded-md bg-white px-3 py-2 font-semibold text-nx-dark shadow-sm transition">
          Magic link
        </button>
        <button id="tab-password" class="rounded-md px-3 py-2 font-semibold text-nx-gray-dark transition hover:text-nx-dark">
          Password
        </button>
      </div>

      <!-- Magic link form -->
      <form id="magic-form" class="mt-6 space-y-4">
        <div>
          <label for="magic-email" class="block text-sm font-medium text-nx-dark">Email</label>
          <input
            type="email" id="magic-email" name="email" required autocomplete="email"
            placeholder="la-tua-email@esempio.it"
            class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-3 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
          />
        </div>
        <p class="text-xs text-nx-gray-dark">Ti invieremo un link via email che scade dopo 15 minuti. Niente password da ricordare.</p>
        <button type="submit"
          class="w-full rounded-lg bg-nx-cyan px-6 py-3 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue disabled:opacity-50">
          Invia il link
        </button>
      </form>

      <!-- Password form -->
      <form id="password-form" class="mt-6 hidden space-y-4">
        <div>
          <label for="pw-email" class="block text-sm font-medium text-nx-dark">Email</label>
          <input
            type="email" id="pw-email" name="email" required autocomplete="email"
            class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-3 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
          />
        </div>
        <div>
          <label for="pw-password" class="block text-sm font-medium text-nx-dark">Password</label>
          <input
            type="password" id="pw-password" name="password" required autocomplete="current-password"
            class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-3 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"
          />
        </div>
        <p class="text-xs text-nx-gray-dark">
          Non hai impostato una password? <button type="button" id="switch-to-magic" class="text-nx-cyan no-underline hover:underline">Accedi con magic link</button> e impostala dal profilo.
        </p>
        <button type="submit"
          class="w-full rounded-lg bg-nx-cyan px-6 py-3 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue disabled:opacity-50">
          Accedi
        </button>
      </form>

      <div id="login-result" class="mt-6 hidden rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800">
        Email inviata. Controlla la posta e clicca il link entro 15 minuti.
      </div>
      <div id="login-error" class="mt-6 hidden rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>

      <p class="mt-8 text-xs text-nx-gray-dark">
        Sei un nuovo socio o hai problemi ad accedere? Scrivi a
        <a href="mailto:info@nexludica.org" class="text-nx-cyan no-underline hover:underline">info@nexludica.org</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const tabMagic = document.getElementById("tab-magic");
    const tabPwd = document.getElementById("tab-password");
    const magicForm = document.getElementById("magic-form");
    const pwdForm = document.getElementById("password-form");
    const ok = document.getElementById("login-result");
    const err = document.getElementById("login-error");
    const switchToMagic = document.getElementById("switch-to-magic");

    function showTab(which) {
      ok.classList.add("hidden"); err.classList.add("hidden");
      if (which === "magic") {
        magicForm.classList.remove("hidden");
        pwdForm.classList.add("hidden");
        tabMagic.classList.add("bg-white", "text-nx-dark", "shadow-sm");
        tabMagic.classList.remove("text-nx-gray-dark");
        tabPwd.classList.remove("bg-white", "text-nx-dark", "shadow-sm");
        tabPwd.classList.add("text-nx-gray-dark");
      } else {
        pwdForm.classList.remove("hidden");
        magicForm.classList.add("hidden");
        tabPwd.classList.add("bg-white", "text-nx-dark", "shadow-sm");
        tabPwd.classList.remove("text-nx-gray-dark");
        tabMagic.classList.remove("bg-white", "text-nx-dark", "shadow-sm");
        tabMagic.classList.add("text-nx-gray-dark");
      }
    }
    tabMagic.addEventListener("click", () => showTab("magic"));
    tabPwd.addEventListener("click", () => showTab("password"));
    switchToMagic.addEventListener("click", () => showTab("magic"));

    magicForm.addEventListener("submit", async function (e) {
      e.preventDefault();
      ok.classList.add("hidden"); err.classList.add("hidden");
      const fd = new FormData(magicForm);
      const email = String(fd.get("email") || "").trim();
      const btn = magicForm.querySelector("button[type=submit]");
      btn.disabled = true;
      try {
        const res = await fetch("/api/auth/request-link", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          err.textContent = data.error || "Errore durante l'invio.";
          err.classList.remove("hidden");
        } else {
          ok.classList.remove("hidden");
          if (data.devLink) {
            const dev = document.createElement("p");
            dev.className = "mt-3 text-xs font-mono text-emerald-900";
            dev.innerHTML = "Dev link: <a href=\"" + data.devLink + "\" class=\"underline\">" + data.devLink + "</a>";
            ok.appendChild(dev);
          }
          magicForm.reset();
        }
      } catch (e) {
        err.textContent = "Errore di rete";
        err.classList.remove("hidden");
      } finally {
        btn.disabled = false;
      }
    });

    pwdForm.addEventListener("submit", async function (e) {
      e.preventDefault();
      ok.classList.add("hidden"); err.classList.add("hidden");
      const fd = new FormData(pwdForm);
      const email = String(fd.get("email") || "").trim();
      const password = String(fd.get("password") || "");
      const btn = pwdForm.querySelector("button[type=submit]");
      btn.disabled = true;
      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          err.textContent = data.error || "Credenziali non valide.";
          err.classList.remove("hidden");
        } else {
          window.location.href = data.redirect || "/area-soci";
        }
      } catch (e) {
        err.textContent = "Errore di rete";
        err.classList.remove("hidden");
      } finally {
        btn.disabled = false;
      }
    });
  })();
</script>
