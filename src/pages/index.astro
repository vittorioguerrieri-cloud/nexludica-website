---
import BaseLayout from "../layouts/BaseLayout.astro";

const partners = [
  {
    name: "Università di Milano-Bicocca",
    role: "Ricerca scientifica",
    logo: "/images/partners/bicocca.png",
  },
  {
    name: "Centro di Solidarietà di Genova",
    role: "Territorio",
    logo: "/images/partners/centro-solidarieta.png",
  },
  {
    name: "Istituto Tecnologie Didattiche — CNR",
    role: "Ricerca didattica",
    logo: "/images/partners/itd-cnr.png",
  },
  {
    name: "Centro di Ricerca sul Gioco — UniGe",
    role: "Network scientifico",
    logo: "/images/partners/cerg-unige.png",
  },
  {
    name: "Acquedotti",
    role: "Game design",
    logo: "/images/partners/acquedotti.png",
  },
  {
    name: "Fondazione Cariplo",
    role: "Co-finanziamento",
    logo: "/images/partners/cariplo.png",
  },
];
---

<BaseLayout title="NexLudica APS — Cultura ludica per l'inclusione sociale">
  <!-- Hero -->
  <section class="nx-hero-pattern px-4 pb-20 pt-20">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2">
      <div class="text-center lg:text-left">
        <h1 class="text-4xl font-extrabold leading-tight text-nx-dark md:text-5xl lg:text-5xl xl:text-6xl" style="font-family: var(--font-display);">
          Il gioco come strumento di trasformazione sociale
        </h1>
        <p class="mt-6 text-lg text-nx-gray-dark">
          Giocare è molto più che un passatempo: è un'esperienza che coinvolge
          mente e relazioni. NexLudica esplora il potenziale del gioco da tavolo
          per il benessere, l'inclusione e lo sviluppo di competenze trasversali.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
          <a
            href="/progetti"
            class="inline-block rounded-lg bg-nx-cyan px-6 py-3 text-sm font-semibold text-white no-underline shadow-md transition hover:bg-nx-blue"
          >
            Scopri i progetti
          </a>
          <a
            href="/supportaci"
            class="inline-block rounded-lg border-2 border-nx-cyan px-6 py-3 text-sm font-semibold text-nx-cyan no-underline transition hover:bg-nx-cyan hover:text-white"
          >
            Supportaci
          </a>
        </div>
      </div>
      <div class="hidden lg:block">
        <img
          src="/images/community.png"
          alt="Momenti dalla comunità NexLudica"
          class="mx-auto w-full max-w-md"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Cosa facciamo -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <h2 class="text-center text-3xl font-bold text-nx-dark">Cosa facciamo</h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-nx-gray-dark">
      Combiniamo ricerca scientifica, sperimentazione sul campo e progettazione partecipata
      per attivare risorse e creare connessioni nei contesti sociali.
    </p>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6 shadow-sm">
        <img src="/images/branding/die-1.svg" alt="" class="mb-4 h-16 w-auto" loading="lazy" />
        <h3 class="text-lg font-semibold text-nx-dark">Game</h3>
        <p class="mt-2 text-sm text-nx-gray-dark">
          Eventi ludici aperti a tutti: serate di gioco da tavolo e gioco di ruolo
          per riconnettere il tessuto sociale.
        </p>
      </div>
      <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6 shadow-sm">
        <img src="/images/branding/die-2.svg" alt="" class="mb-4 h-16 w-auto" loading="lazy" />
        <h3 class="text-lg font-semibold text-nx-dark">Research</h3>
        <p class="mt-2 text-sm text-nx-gray-dark">
          Studiamo il ruolo motivazionale e psicologico del gioco da tavolo, in
          collaborazione con università ed enti di ricerca.
        </p>
      </div>
      <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6 shadow-sm">
        <img src="/images/branding/die-3.svg" alt="" class="mb-4 h-16 w-auto" loading="lazy" />
        <h3 class="text-lg font-semibold text-nx-dark">Inclusion</h3>
        <p class="mt-2 text-sm text-nx-gray-dark">
          Progettiamo interventi inclusivi per giovani NEET, persone in carcere
          e contesti fragili attraverso il gioco.
        </p>
      </div>
    </div>
  </section>

  <!-- Partner -->
  <section class="bg-nx-off-white px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-3xl font-bold text-nx-dark">I nostri partner</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-nx-gray-dark">
        Lavoriamo con università, enti di ricerca e realtà del terzo settore.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {partners.map((p) => (
          <div class="flex flex-col items-center rounded-lg border border-nx-gray-light/20 bg-white p-6 text-center transition hover:shadow-md">
            <div class="flex h-24 w-full items-center justify-center">
              <img
                src={p.logo}
                alt={p.name}
                class="max-h-full max-w-full object-contain"
                loading="lazy"
              />
            </div>
            <p class="mt-4 text-sm font-semibold text-nx-dark">{p.name}</p>
            <p class="mt-1 text-xs uppercase tracking-wider text-nx-cyan">{p.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Donazione -->
  <section class="bg-nx-blue-deep px-4 py-16 text-center text-white">
    <h2 class="text-3xl font-bold">Sostieni la nostra missione</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/80">
      Con il tuo contributo possiamo continuare a portare il gioco dove serve di più.
      Ogni donazione fa la differenza.
    </p>
    <a
      href="/supportaci"
      class="mt-8 inline-block rounded-lg bg-nx-accent px-8 py-3 text-sm font-bold text-nx-dark no-underline shadow-md transition hover:bg-amber-400"
    >
      Dona ora
    </a>
  </section>
</BaseLayout>
