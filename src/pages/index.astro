---
import BaseLayout from "../layouts/BaseLayout.astro";

const partners = [
  {
    name: "Università di Milano-Bicocca",
    role: "Ricerca scientifica",
    logo: "/images/partners/bicocca.png",
  },
  {
    name: "Centro di Solidarietà di Genova",
    role: "Territorio",
    logo: "/images/partners/centro-solidarieta.png",
  },
  {
    name: "Istituto Tecnologie Didattiche — CNR",
    role: "Ricerca didattica",
    logo: "/images/partners/itd-cnr.png",
  },
  {
    name: "Centro di Ricerca sul Gioco — UniGe",
    role: "Network scientifico",
    logo: "/images/partners/cerg-unige.png",
  },
  {
    name: "Acquedotti",
    role: "Game design",
    logo: "/images/partners/acquedotti.png",
  },
  {
    name: "Fondazione Cariplo",
    role: "Co-finanziamento",
    logo: "/images/partners/cariplo.png",
  },
];
---

<BaseLayout title="NexLudica APS — Cultura ludica per l'inclusione sociale">
  <!-- Hero: tipografia gigante con accent evidenziatore -->
  <section class="relative overflow-hidden bg-nx-off-white px-4 pb-24 pt-24 lg:pb-32 lg:pt-32">
    <div class="relative mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.3em] text-nx-cyan">
          Game · Research · Inclusion
        </p>
        <h1 class="mt-6 text-5xl font-black leading-[1.05] tracking-tight text-nx-dark sm:text-6xl lg:text-7xl xl:text-[5.5rem]" style="font-family: var(--font-display);">
          Ricerca ludica,<br />
          <span class="relative inline-block">
            <span class="relative z-10">connessione</span>
            <span class="absolute inset-x-0 bottom-1 -z-0 h-4 bg-nx-cyan/30 lg:bottom-2 lg:h-6"></span>
          </span>
          <br />
          sociale.
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-nx-gray-dark">
          Studiamo il gioco da tavolo come strumento di ricerca scientifica e
          come occasione di incontro: per generare conoscenza e per costruire
          relazioni.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href="/progetti"
            class="inline-block rounded-lg bg-nx-cyan px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white no-underline shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue hover:shadow-xl"
          >
            Scopri i progetti
          </a>
          <a
            href="/supportaci"
            class="inline-block border-b-2 border-nx-dark px-2 py-2 text-sm font-bold uppercase tracking-wider text-nx-dark no-underline transition hover:border-nx-cyan hover:text-nx-cyan"
          >
            Supportaci →
          </a>
        </div>
      </div>
      <div class="hidden lg:block">
        <img
          src="/images/community.png"
          alt="Momenti dalla comunità NexLudica"
          class="w-full"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Cosa facciamo -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <h2 class="text-center text-3xl font-bold text-nx-dark">Cosa facciamo</h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-nx-gray-dark">
      Combiniamo ricerca scientifica, sperimentazione sul campo e progettazione partecipata
      per attivare risorse e creare connessioni nei contesti sociali.
    </p>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6 shadow-sm">
        <img src="/images/branding/die-1.svg" alt="" class="mb-4 h-16 w-auto" loading="lazy" />
        <h3 class="text-lg font-semibold text-nx-dark">Game</h3>
        <p class="mt-2 text-sm text-nx-gray-dark">
          Il gioco da tavolo è il nostro linguaggio e il nostro strumento.
          Crediamo nel suo potere di trasformare, motivare e connettere chi gioca.
        </p>
      </div>
      <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6 shadow-sm">
        <img src="/images/branding/die-2.svg" alt="" class="mb-4 h-16 w-auto" loading="lazy" />
        <h3 class="text-lg font-semibold text-nx-dark">Research</h3>
        <p class="mt-2 text-sm text-nx-gray-dark">
          Facciamo ricerca sul gioco da tavolo e con il gioco da tavolo.
          Lo usiamo per esplorare il comportamento umano, la tecnologia e le
          dinamiche sociali.
        </p>
      </div>
      <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6 shadow-sm">
        <img src="/images/branding/die-3.svg" alt="" class="mb-4 h-16 w-auto" loading="lazy" />
        <h3 class="text-lg font-semibold text-nx-dark">Inclusion</h3>
        <p class="mt-2 text-sm text-nx-gray-dark">
          Abbiamo l'obiettivo di creare spazi di crescita e connessione.
          Ognuno in NexLudica ha occasione di contribuire e sentirsi parte
          di qualcosa più grande.
        </p>
      </div>
    </div>
  </section>

  <!-- Partner -->
  <section class="bg-nx-off-white px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-3xl font-bold text-nx-dark">I nostri partner</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-nx-gray-dark">
        Lavoriamo con università, enti di ricerca e realtà del terzo settore.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {partners.map((p) => (
          <div class="flex flex-col items-center rounded-lg border border-nx-gray-light/20 bg-white p-6 text-center transition hover:shadow-md">
            <div class="flex h-24 w-full items-center justify-center">
              <img
                src={p.logo}
                alt={p.name}
                class="max-h-full max-w-full object-contain"
                loading="lazy"
              />
            </div>
            <p class="mt-4 text-sm font-semibold text-nx-dark">{p.name}</p>
            <p class="mt-1 text-xs uppercase tracking-wider text-nx-cyan">{p.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
