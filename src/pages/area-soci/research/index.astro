---
import AreaSociLayout from "../../../layouts/AreaSociLayout.astro";
import { getDb, getEnv } from "../../../server/db";
import { getUser } from "../../../server/guards";
import { listStudies, countResponses, type Study } from "../../../server/research";

export const prerender = false;

const user = await getUser(Astro);
if (!user) return Astro.redirect("/login");
if (user.role !== "admin") return Astro.redirect("/area-soci");

const env = await getEnv();
const db = getDb(env as Env);
let studies: Study[] = [];
const counts = new Map<string, number>();
if (db) {
  studies = await listStudies(db);
  for (const s of studies) {
    const cs = await countResponses(db, s.id);
    counts.set(s.id, cs.reduce((acc, c) => acc + c.count, 0));
  }
}

const statusLabel: Record<string, string> = {
  draft: "Bozza",
  active: "Attivo",
  closed: "Chiuso",
};
const statusColor: Record<string, string> = {
  draft: "bg-amber-100 text-amber-800",
  active: "bg-emerald-100 text-emerald-800",
  closed: "bg-nx-gray-light/30 text-nx-gray-dark",
};
---

<AreaSociLayout title="Research Platform — Amministrazione" active="research">
  <div class="flex flex-wrap items-baseline justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold text-nx-dark">Research Platform</h2>
      <p class="mt-1 text-sm text-nx-gray-dark">
        Gestione studi e questionari psicometrici pubblicati su
        <a href="https://research.nexludica.org" target="_blank" rel="noopener noreferrer" class="text-nx-cyan no-underline hover:underline">research.nexludica.org</a>.
      </p>
    </div>
    <a
      href="/area-soci/research/new"
      class="rounded-lg bg-nx-cyan px-5 py-2.5 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue no-underline"
    >
      + Nuovo studio
    </a>
  </div>

  {studies.length === 0 ? (
    <div class="mt-8 rounded-xl border-2 border-dashed border-nx-gray-light/40 bg-white p-12 text-center">
      <p class="text-base font-semibold text-nx-dark">Nessuno studio creato</p>
      <p class="mt-2 text-sm text-nx-gray-dark">Crea il primo studio per iniziare a raccogliere dati.</p>
    </div>
  ) : (
    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {studies.map((s) => (
        <a
          href={`/area-soci/research/${s.id}`}
          class="group flex flex-col gap-3 rounded-xl border border-nx-gray-light/20 bg-white p-5 no-underline transition hover:border-nx-cyan hover:shadow-md"
        >
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-base font-bold text-nx-dark">{s.title}</h3>
            <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wider ${statusColor[s.status]}`}>
              {statusLabel[s.status]}
            </span>
          </div>
          <p class="font-mono text-xs text-nx-gray-dark">{s.slug}</p>
          {s.description && (
            <p class="line-clamp-3 text-sm text-nx-gray-dark">{s.description}</p>
          )}
          <div class="mt-2 flex items-center justify-between border-t border-nx-gray-light/20 pt-3">
            <div>
              <p class="text-xs text-nx-gray-dark">Risposte raccolte</p>
              <p class="text-xl font-black text-nx-dark">{counts.get(s.id) ?? 0}</p>
            </div>
            <span class="text-xs font-semibold text-nx-cyan group-hover:translate-x-0.5">Gestisci →</span>
          </div>
        </a>
      ))}
    </div>
  )}
</AreaSociLayout>
