---
import AreaSociLayout from "../../../layouts/AreaSociLayout.astro";
import { getDb } from "../../../server/db";
import { listMyArticles } from "../../../server/articles";

export const prerender = false;

const user = (Astro.locals as any).user as { id: string; name: string } | null;
// @ts-expect-error
const env: Env | undefined = Astro.locals?.runtime?.env;
const db = env ? getDb(env) : null;
const articles = (db && user) ? await listMyArticles(db, user.id) : [];
---

<AreaSociLayout title="I miei articoli — Area Soci" active="articoli">
  <div class="flex flex-wrap items-baseline justify-between gap-4">
    <div>
      <h2 class="text-2xl font-bold text-nx-dark">I miei resoconti MeetLudica</h2>
      <p class="mt-1 text-sm text-nx-gray-dark">
        Gestisci i resoconti che hai pubblicato. Quelli "published" appaiono nell'archivio pubblico.
      </p>
    </div>
    <a href="/area-soci/articoli/nuovo" class="rounded-lg bg-nx-cyan px-5 py-2.5 text-sm font-bold uppercase tracking-wider text-white no-underline shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue">
      + Nuovo resoconto
    </a>
  </div>

  {articles.length === 0 ? (
    <div class="mt-8 rounded-xl border-2 border-dashed border-nx-gray-light/40 bg-white p-12 text-center">
      <p class="text-base font-semibold text-nx-dark">Nessun resoconto ancora</p>
      <p class="mt-2 text-sm text-nx-gray-dark">Pubblica il tuo primo resoconto MeetLudica.</p>
      <a href="/area-soci/articoli/nuovo" class="mt-4 inline-block rounded-lg bg-nx-cyan px-5 py-2.5 text-sm font-bold uppercase tracking-wider text-white no-underline transition hover:bg-nx-blue">
        Carica resoconto
      </a>
    </div>
  ) : (
    <ul class="mt-8 space-y-4">
      {articles.map((a) => (
        <li class="rounded-xl border border-nx-gray-light/20 bg-white p-6">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <span class={`rounded-full px-2 py-0.5 text-xs font-bold uppercase tracking-wider ${
                  a.status === "published" ? "bg-emerald-100 text-emerald-700"
                  : a.status === "draft" ? "bg-amber-100 text-amber-700"
                  : "bg-nx-gray-light/30 text-nx-gray-dark"
                }`}>{a.status}</span>
                <span class="text-xs text-nx-gray-dark">{a.meetingDate}</span>
              </div>
              <h3 class="mt-2 text-lg font-bold text-nx-dark">{a.title}</h3>
              <p class="mt-1 text-sm text-nx-gray-dark">{a.speaker}</p>
              <p class="mt-3 line-clamp-3 text-sm text-nx-gray-dark">{a.abstract}</p>
              <div class="mt-3 flex flex-wrap gap-3 text-xs">
                {a.documentUrl && (
                  <a href={a.documentUrl} target="_blank" rel="noopener noreferrer" class="text-nx-cyan no-underline hover:underline">📄 PDF</a>
                )}
                {a.videoUrl && (
                  <a href={a.videoUrl} target="_blank" rel="noopener noreferrer" class="text-nx-cyan no-underline hover:underline">▶ Video</a>
                )}
              </div>
            </div>
            <button
              data-delete-id={a.id}
              data-delete-title={a.title}
              class="js-delete shrink-0 rounded-md border border-red-200 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-red-700 transition hover:bg-red-50"
            >
              Elimina
            </button>
          </div>
        </li>
      ))}
    </ul>
  )}
</AreaSociLayout>

<script is:inline>
  (function () {
    document.querySelectorAll(".js-delete").forEach(function (btn) {
      btn.addEventListener("click", async function () {
        const id = btn.getAttribute("data-delete-id");
        const title = btn.getAttribute("data-delete-title") || "questo articolo";
        if (!confirm(`Eliminare "${title}"? L'azione è irreversibile.`)) return;
        btn.disabled = true;
        const res = await fetch("/api/articles/" + encodeURIComponent(id), { method: "DELETE" });
        if (res.ok) {
          window.location.reload();
        } else {
          alert("Errore durante l'eliminazione");
          btn.disabled = false;
        }
      });
    });
  })();
</script>
