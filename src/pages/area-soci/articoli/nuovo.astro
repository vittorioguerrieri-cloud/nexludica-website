---
import AreaSociLayout from "../../../layouts/AreaSociLayout.astro";

export const prerender = false;
---

<AreaSociLayout title="Nuovo resoconto — Area Soci" active="articoli">
  <a href="/area-soci/articoli" class="text-sm text-nx-gray-dark no-underline hover:text-nx-cyan">
    ← Torna ai miei articoli
  </a>

  <div class="mt-4 rounded-xl border border-nx-gray-light/20 bg-white p-8">
    <h2 class="text-2xl font-bold text-nx-dark">Carica un resoconto MeetLudica</h2>
    <p class="mt-2 text-sm text-nx-gray-dark">
      Compila i dati del talk: il resoconto sarà pubblicato sull'archivio della pagina
      <a href="/meetludica" class="text-nx-cyan no-underline hover:underline">MeetLudica</a>.
    </p>

    <form id="article-form" class="mt-8 space-y-5" enctype="multipart/form-data">
      <div class="grid gap-5 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label for="title" class="block text-sm font-medium text-nx-dark">Titolo del talk *</label>
          <input type="text" id="title" name="title" required maxlength="200"
                 placeholder="es. Tabletop Science: gioco e ricerca"
                 class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20" />
        </div>
        <div>
          <label for="speaker" class="block text-sm font-medium text-nx-dark">Relatore/i *</label>
          <input type="text" id="speaker" name="speaker" required maxlength="200"
                 placeholder="Nome Cognome"
                 class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20" />
        </div>
        <div>
          <label for="meetingDate" class="block text-sm font-medium text-nx-dark">Data dell'incontro *</label>
          <input type="date" id="meetingDate" name="meetingDate" required
                 class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20" />
        </div>
        <div class="sm:col-span-2">
          <label for="tags" class="block text-sm font-medium text-nx-dark">Tag (separati da virgola)</label>
          <input type="text" id="tags" name="tags" maxlength="200"
                 placeholder="ricerca, design, NEET"
                 class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20" />
        </div>
        <div class="sm:col-span-2">
          <label for="abstract" class="block text-sm font-medium text-nx-dark">Abstract *</label>
          <textarea id="abstract" name="abstract" rows="6" required maxlength="5000"
                    placeholder="Sintesi del talk e dei principali spunti emersi nella discussione."
                    class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20"></textarea>
        </div>
        <div class="sm:col-span-2">
          <label for="document" class="block text-sm font-medium text-nx-dark">Documento PDF</label>
          <input type="file" id="document" name="document" accept="application/pdf"
                 class="mt-1 block w-full rounded-lg border border-dashed border-nx-gray-light/40 bg-nx-off-white px-4 py-3 text-sm text-nx-dark outline-none file:mr-4 file:rounded-md file:border-0 file:bg-nx-cyan file:px-4 file:py-2 file:text-xs file:font-bold file:uppercase file:tracking-wider file:text-white" />
          <p class="mt-1 text-xs text-nx-gray-dark">Max 10 MB. Formato consigliato: PDF.</p>
        </div>
        <div class="sm:col-span-2">
          <label for="videoUrl" class="block text-sm font-medium text-nx-dark">Link registrazione (opzionale)</label>
          <input type="url" id="videoUrl" name="videoUrl" maxlength="500"
                 placeholder="https://"
                 class="mt-1 block w-full rounded-lg border border-nx-gray-light/40 px-4 py-2.5 text-sm text-nx-dark outline-none transition focus:border-nx-cyan focus:ring-2 focus:ring-nx-cyan/20" />
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-nx-dark">Stato di pubblicazione</label>
          <div class="mt-2 flex gap-4 text-sm">
            <label class="flex items-center gap-2">
              <input type="radio" name="status" value="published" checked class="h-4 w-4 text-nx-cyan" />
              <span>Pubblicato (visibile a tutti)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="status" value="draft" class="h-4 w-4 text-nx-cyan" />
              <span>Bozza (visibile solo a me)</span>
            </label>
          </div>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-4 pt-2">
        <button type="submit" class="rounded-lg bg-nx-cyan px-7 py-3 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue disabled:opacity-50">
          Pubblica resoconto
        </button>
        <a href="/area-soci/articoli" class="text-sm text-nx-gray-dark no-underline hover:text-nx-cyan">
          Annulla
        </a>
        <span id="article-status" class="text-sm text-nx-gray-dark"></span>
      </div>
    </form>
  </div>
</AreaSociLayout>

<script is:inline>
  (function () {
    const form = document.getElementById("article-form");
    const status = document.getElementById("article-status");
    if (!form) return;
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      status.textContent = "Caricamento in corso...";
      status.className = "text-sm text-nx-gray-dark";
      const fd = new FormData(form);
      const btn = form.querySelector("button[type=submit]");
      btn.disabled = true;
      try {
        const res = await fetch("/api/articles", { method: "POST", body: fd });
        const data = await res.json();
        if (!res.ok || !data.ok) {
          status.textContent = "Errore: " + (data.error || res.status);
          status.className = "text-sm text-red-600";
          btn.disabled = false;
        } else {
          status.textContent = "✓ Pubblicato. Reindirizzamento...";
          status.className = "text-sm text-emerald-600";
          setTimeout(() => { window.location.href = "/area-soci/articoli"; }, 800);
        }
      } catch (e) {
        status.textContent = "Errore di rete";
        status.className = "text-sm text-red-600";
        btn.disabled = false;
      }
    });
  })();
</script>
