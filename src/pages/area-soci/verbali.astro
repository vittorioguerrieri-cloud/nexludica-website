---
import AreaSociLayout from "../../layouts/AreaSociLayout.astro";
import { getEnv } from "../../server/db";
import { listFolders, type DriveFolder } from "../../server/drive";

export const prerender = false;

const env = await getEnv();
const rootId = (env as Env).DRIVE_ROOT_FOLDER_ID;
let folders: DriveFolder[] = [];
let driveError: string | null = null;
if (rootId) {
  try {
    folders = await listFolders(env as Env, rootId);
  } catch (e) {
    driveError = String(e);
    console.error("[verbali] drive list failed:", e);
  }
} else {
  driveError = "DRIVE_ROOT_FOLDER_ID non configurato";
}

// Icone tematiche per nomi cartella ricorrenti
function iconFor(name: string): string {
  const n = name.toLowerCase();
  if (n.includes("verbal")) return "▤";
  if (n.includes("statut") || n.includes("atto")) return "📜";
  if (n.includes("bilanc") || n.includes("rendicont")) return "₿";
  if (n.includes("modul") || n.includes("soci")) return "✎";
  if (n.includes("comunic") || n.includes("brand") || n.includes("grafic")) return "♦";
  if (n.includes("progett") || n.includes("ricerca")) return "▴";
  return "▣";
}
---

<AreaSociLayout title="Verbali e documenti — Area Soci" active="verbali">
  <div>
    <h2 class="text-2xl font-bold text-nx-dark">Verbali e documenti dell'associazione</h2>
    <p class="mt-2 max-w-3xl text-sm text-nx-gray-dark">
      Cartelle Google Drive con i documenti utili alla vita dell'associazione. Click per
      aprire la cartella su Drive — l'accesso richiede di essere loggato con un account
      condiviso (chiedi a Vittorio se non vedi il contenuto).
    </p>
  </div>

  {driveError && (
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      <strong>Drive non disponibile:</strong> {driveError}
    </div>
  )}

  {folders.length === 0 && !driveError && (
    <div class="mt-8 rounded-xl border-2 border-dashed border-nx-gray-light/40 bg-nx-off-white p-12 text-center">
      <p class="text-base font-semibold text-nx-dark">Nessuna cartella ancora</p>
      <p class="mt-2 text-sm text-nx-gray-dark">
        Crea le sottocartelle nel tuo Drive — le vedrai qui automaticamente.
      </p>
    </div>
  )}

  {folders.length > 0 && (
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {folders.map((f) => (
        <a
          href={f.webViewLink}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex gap-4 rounded-xl border border-nx-gray-light/20 bg-white p-6 no-underline transition hover:border-nx-cyan hover:shadow-md"
        >
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-nx-cyan-light text-xl text-nx-cyan">
            {iconFor(f.name)}
          </span>
          <div class="min-w-0">
            <p class="text-base font-bold text-nx-dark">{f.name}</p>
            <p class="mt-1 text-xs text-nx-gray-dark">
              Aggiornata: {new Date(f.modifiedTime).toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" })}
            </p>
            <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-nx-cyan">
              Apri su Drive →
            </p>
          </div>
        </a>
      ))}
    </div>
  )}

</AreaSociLayout>
