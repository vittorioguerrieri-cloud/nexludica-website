---
import AreaSociLayout from "../layouts/AreaSociLayout.astro";
import { getDb } from "../server/db";
import { listMyArticles } from "../server/articles";
import { getMyProfile } from "../server/profiles";
import { getUser } from "../server/guards";

export const prerender = false;

const user = await getUser(Astro);
if (!user) {
  return Astro.redirect("/login");
}
// @ts-expect-error
const env: Env | undefined = Astro.locals?.runtime?.env;
const db = env ? getDb(env) : null;

let myArticles: Awaited<ReturnType<typeof listMyArticles>> = [];
let profile: Awaited<ReturnType<typeof getMyProfile>> = null;
if (db) {
  try {
    [myArticles, profile] = await Promise.all([
      listMyArticles(db, user.id),
      getMyProfile(db, user.id),
    ]);
  } catch (e) {
    console.error("[area-soci] db error:", e);
  }
}

const profileCompleteness = (() => {
  if (!profile) return 0;
  const fields: Array<keyof typeof profile> = ["roleLabel", "bio", "skills", "photoUrl"];
  const filled = fields.filter((f) => profile && profile[f]).length;
  return Math.round((filled / fields.length) * 100);
})();
---

<AreaSociLayout title="Dashboard — Area Soci" active="dashboard">
  <!-- Welcome cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6">
      <p class="text-xs font-bold uppercase tracking-wider text-nx-gray-dark">Profilo pubblico</p>
      <p class="mt-2 text-3xl font-black text-nx-dark">{profileCompleteness}%</p>
      <p class="mt-1 text-sm text-nx-gray-dark">
        Completezza del tuo profilo {profile?.publicVisible ? "(visibile su Chi siamo)" : "(nascosto)"}.
      </p>
      <a href="/area-soci/profilo" class="mt-4 inline-block text-sm font-semibold text-nx-cyan no-underline hover:underline">
        Aggiorna →
      </a>
    </div>
    <div class="rounded-xl border border-nx-gray-light/20 bg-white p-6">
      <p class="text-xs font-bold uppercase tracking-wider text-nx-gray-dark">I tuoi articoli</p>
      <p class="mt-2 text-3xl font-black text-nx-dark">{myArticles.length}</p>
      <p class="mt-1 text-sm text-nx-gray-dark">
        Resoconti MeetLudica pubblicati a tuo nome.
      </p>
      <a href="/area-soci/articoli" class="mt-4 inline-block text-sm font-semibold text-nx-cyan no-underline hover:underline">
        Gestisci →
      </a>
    </div>
    <div class="rounded-xl border border-nx-gray-light/20 bg-nx-cyan-light p-6">
      <p class="text-xs font-bold uppercase tracking-wider text-nx-cyan">Carica un resoconto</p>
      <p class="mt-2 text-lg font-bold text-nx-dark">Hai presentato a un MeetLudica?</p>
      <p class="mt-1 text-sm text-nx-dark/80">
        Pubblica il tuo resoconto: comparirà nell'archivio pubblico.
      </p>
      <a href="/area-soci/articoli/nuovo" class="mt-4 inline-block rounded-lg bg-nx-cyan px-5 py-2 text-sm font-bold uppercase tracking-wider text-white no-underline transition hover:bg-nx-blue">
        Nuovo resoconto
      </a>
    </div>
  </div>

  <!-- Recent activity -->
  <div class="mt-10">
    <h2 class="text-xl font-bold text-nx-dark">I tuoi ultimi articoli</h2>
    {myArticles.length === 0 ? (
      <div class="mt-4 rounded-xl border-2 border-dashed border-nx-gray-light/40 bg-white p-8 text-center">
        <p class="text-sm text-nx-gray-dark">Non hai ancora pubblicato nessun resoconto.</p>
        <a href="/area-soci/articoli/nuovo" class="mt-3 inline-block text-sm font-semibold text-nx-cyan no-underline hover:underline">
          Carica il primo →
        </a>
      </div>
    ) : (
      <ul class="mt-4 space-y-3">
        {myArticles.slice(0, 5).map((a) => (
          <li class="flex items-center justify-between gap-4 rounded-lg border border-nx-gray-light/20 bg-white p-4">
            <div class="min-w-0">
              <p class="truncate text-sm font-semibold text-nx-dark">{a.title}</p>
              <p class="mt-0.5 text-xs text-nx-gray-dark">
                {a.speaker} · {a.meetingDate} · <span class="uppercase">{a.status}</span>
              </p>
            </div>
            <a href={`/area-soci/articoli`} class="text-xs font-semibold text-nx-cyan no-underline hover:underline">Gestisci</a>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Quick links -->
  <div class="mt-10 rounded-xl border border-nx-gray-light/20 bg-nx-off-white p-6">
    <p class="text-xs font-bold uppercase tracking-wider text-nx-gray-dark">Risorse rapide</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <a href="/area-soci/verbali" class="flex items-center gap-3 rounded-lg bg-white p-4 no-underline transition hover:shadow-md">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-nx-cyan-light text-nx-cyan">▤</span>
        <div>
          <p class="text-sm font-semibold text-nx-dark">Verbali e documenti</p>
          <p class="text-xs text-nx-gray-dark">Cartella Drive con verbali assemblee, statuto e atti</p>
        </div>
      </a>
      <a href="/meetludica" class="flex items-center gap-3 rounded-lg bg-white p-4 no-underline transition hover:shadow-md">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-nx-cyan-light text-nx-cyan">★</span>
        <div>
          <p class="text-sm font-semibold text-nx-dark">Pagina MeetLudica</p>
          <p class="text-xs text-nx-gray-dark">Calendario incontri e archivio resoconti pubblici</p>
        </div>
      </a>
    </div>
  </div>
</AreaSociLayout>
