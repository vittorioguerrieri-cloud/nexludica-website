---
import BaseLayout from "../layouts/BaseLayout.astro";
import { upcomingMeetings } from "../lib/meetludica";
import { getDb } from "../server/db";
import { listPublishedArticles, type PublicArticle } from "../server/articles";

export const prerender = false;

const meetings = upcomingMeetings(6);

// @ts-expect-error
const env: Env | undefined = Astro.locals?.runtime?.env;
const db = env ? getDb(env) : null;
let articles: PublicArticle[] = [];
if (db) {
  try {
    articles = await listPublishedArticles(db);
  } catch {
    articles = [];
  }
}
---

<BaseLayout title="MeetLudica — NexLudica APS" description="MeetLudica: il network mensile di chi fa ricerca sul gioco da tavolo. Ultimo giovedì del mese, 20:30. Calendario, archivio articoli e modalità di partecipazione.">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-nx-off-white px-4 pb-20 pt-28 lg:pt-32">
    <div class="relative mx-auto max-w-4xl">
      <p class="text-sm font-bold uppercase tracking-[0.3em] text-nx-cyan">
        Network · Ricerca ludica
      </p>
      <h1 class="mt-4 text-5xl font-black leading-[1.05] tracking-tight text-nx-dark sm:text-6xl lg:text-7xl" style="font-family: var(--font-display);">
        Meet<span class="text-nx-cyan">Ludica</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-nx-gray-dark">
        Un incontro mensile per <strong class="text-nx-dark">unire ricercatrici e ricercatori
        sul gioco da tavolo</strong>, restare connessi e aggiornati sul panorama della ricerca
        ludica.
      </p>
      <p class="mt-4 max-w-2xl text-base text-nx-gray-dark">
        L'obiettivo è rendere la ricerca ludica più accessibile, favorire la connessione tra
        ricercatori e dare risonanza a progetti meritevoli.
      </p>
    </div>
  </section>

  <!-- Come funziona -->
  <section class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-3xl font-bold text-nx-dark">Come funziona</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      <div class="rounded-xl border-l-4 border-nx-cyan bg-nx-off-white p-6">
        <p class="text-xs font-bold uppercase tracking-wider text-nx-cyan">Quando</p>
        <p class="mt-2 text-lg font-semibold text-nx-dark">Ultimo giovedì del mese</p>
        <p class="mt-1 text-sm text-nx-gray-dark">Ore 20:30, online.</p>
      </div>
      <div class="rounded-xl border-l-4 border-nx-cyan bg-nx-off-white p-6">
        <p class="text-xs font-bold uppercase tracking-wider text-nx-cyan">Talk</p>
        <p class="mt-2 text-lg font-semibold text-nx-dark">30 minuti</p>
        <p class="mt-1 text-sm text-nx-gray-dark">
          Presentazione di un progetto di ricerca in corso.
        </p>
      </div>
      <div class="rounded-xl border-l-4 border-nx-cyan bg-nx-off-white p-6">
        <p class="text-xs font-bold uppercase tracking-wider text-nx-cyan">Discussione</p>
        <p class="mt-2 text-lg font-semibold text-nx-dark">~ 1 ora</p>
        <p class="mt-1 text-sm text-nx-gray-dark">
          Domande, osservazioni, criticità, idee.
        </p>
      </div>
    </div>
    <p class="mt-8 max-w-3xl text-base leading-relaxed text-nx-gray-dark">
      Dopo ogni incontro pubblichiamo un <strong class="text-nx-dark">resoconto</strong> con
      il riepilogo del progetto presentato e i feedback emersi durante la discussione.
      I soci possono caricare i propri resoconti dalla
      <a href="/area-soci/articoli/nuovo" class="text-nx-cyan no-underline hover:underline">area soci</a>.
    </p>
  </section>

  <!-- Calendario -->
  <section class="bg-nx-blue-deep px-4 py-20 text-white">
    <div class="mx-auto max-w-5xl">
      <div class="flex flex-wrap items-baseline justify-between gap-4">
        <h2 class="text-3xl font-bold">Prossimi appuntamenti</h2>
        <p class="text-sm text-white/60">Ricorrenza: ogni ultimo giovedì del mese, 20:30</p>
      </div>
      <ul class="mt-10 space-y-3">
        {meetings.map((m, i) => (
          <li class={`flex items-center gap-6 rounded-lg p-5 transition ${
            i === 0 ? "bg-nx-cyan text-nx-dark" : "bg-white/5 hover:bg-white/10"
          }`}>
            <div class="flex shrink-0 flex-col items-center justify-center rounded-md bg-white/90 px-4 py-2 text-nx-dark">
              <span class="text-xs font-bold uppercase tracking-wider">
                {m.date.toLocaleDateString("it-IT", { month: "short" }).replace(".", "")}
              </span>
              <span class="text-2xl font-black leading-none">
                {m.date.getDate()}
              </span>
              <span class="text-xs">{m.date.getFullYear()}</span>
            </div>
            <div class="flex-1">
              <p class={`text-base font-semibold ${i === 0 ? "text-nx-dark" : "text-white"}`}>
                {m.label}
              </p>
              <p class={`text-sm ${i === 0 ? "text-nx-dark/70" : "text-white/60"}`}>
                {i === 0 ? "Prossimo incontro" : "Programmato"}
              </p>
            </div>
          </li>
        ))}
      </ul>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="mailto:info@nexludica.org?subject=Iscrizione%20MeetLudica"
          class="inline-block rounded-lg bg-white px-6 py-3 text-sm font-bold uppercase tracking-wider text-nx-dark no-underline transition hover:bg-nx-cyan-light"
        >
          Voglio partecipare
        </a>
        <a
          href="mailto:info@nexludica.org?subject=Proposta%20talk%20MeetLudica"
          class="inline-block border-b-2 border-white px-2 py-2 text-sm font-bold uppercase tracking-wider text-white no-underline transition hover:border-nx-cyan hover:text-nx-cyan"
        >
          Proponi un talk →
        </a>
      </div>
    </div>
  </section>

  <!-- Archivio articoli -->
  <section class="mx-auto max-w-5xl px-4 py-20">
    <div class="flex flex-wrap items-baseline justify-between gap-4">
      <h2 class="text-3xl font-bold text-nx-dark">Archivio dei resoconti</h2>
      <p class="text-sm text-nx-gray-dark">
        {articles.length} {articles.length === 1 ? "articolo pubblicato" : "articoli pubblicati"}
      </p>
    </div>

    {articles.length === 0 ? (
      <div class="mt-10 rounded-xl border-2 border-dashed border-nx-gray-light/40 bg-nx-off-white p-12 text-center">
        <p class="text-lg font-semibold text-nx-dark">L'archivio sta crescendo</p>
        <p class="mt-2 text-nx-gray-dark">
          Dopo i primi MeetLudica troverai qui i resoconti delle presentazioni, con
          abstract e materiali dei relatori.
        </p>
        <p class="mt-4 text-sm text-nx-gray-dark">
          Sei un socio?
          <a href="/area-soci/articoli/nuovo" class="font-semibold text-nx-cyan no-underline hover:underline">
            Carica il primo resoconto
          </a>.
        </p>
      </div>
    ) : (
      <ul class="mt-10 space-y-6">
        {articles.map((a) => (
          <li class="rounded-xl border border-nx-gray-light/20 bg-white p-6 transition hover:shadow-md">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <h3 class="text-xl font-bold text-nx-dark">{a.title}</h3>
                <p class="mt-1 text-sm text-nx-gray-dark">
                  {a.speaker} · {new Date(a.meetingDate).toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" })}
                </p>
                <p class="mt-0.5 text-xs text-nx-gray-dark">
                  Caricato da {a.authorName}
                </p>
              </div>
              {a.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {a.tags.map((t) => (
                    <span class="rounded-full bg-nx-cyan-light px-3 py-1 text-xs font-medium text-nx-cyan">
                      {t}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <p class="mt-3 leading-relaxed text-nx-gray-dark whitespace-pre-line">{a.abstract}</p>
            <div class="mt-4 flex flex-wrap gap-4">
              {a.documentUrl && (
                <a href={a.documentUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-nx-cyan no-underline hover:underline">
                  📄 Leggi il resoconto
                </a>
              )}
              {a.videoUrl && (
                <a href={a.videoUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-nx-cyan no-underline hover:underline">
                  ▶ Guarda la registrazione
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- CTA partecipa -->
  <section class="bg-nx-off-white px-4 py-16">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-nx-dark">Unisciti al network</h2>
      <p class="mx-auto mt-4 max-w-xl text-nx-gray-dark">
        MeetLudica è aperto a chiunque faccia ricerca, design o pratica educativa
        attorno al gioco da tavolo. Scrivici per iscriverti o per proporre un talk.
      </p>
      <a
        href="mailto:info@nexludica.org?subject=Iscrizione%20MeetLudica"
        class="mt-8 inline-block rounded-lg bg-nx-cyan px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white no-underline shadow-lg shadow-nx-cyan/30 transition hover:-translate-y-0.5 hover:bg-nx-blue"
      >
        Scrivici per iscriverti
      </a>
    </div>
  </section>
</BaseLayout>
