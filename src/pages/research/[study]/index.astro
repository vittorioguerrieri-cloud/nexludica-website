---
import ResearchLayout from "../../../layouts/ResearchLayout.astro";
import { getDb, getEnv } from "../../../server/db";
import { getStudyBySlug, listQuestionnaires } from "../../../server/research";

export const prerender = false;

const slug = Astro.params.study as string;
const env = await getEnv();
const db = getDb(env as Env);
if (!db) return new Response("Backend non disponibile", { status: 503 });

const study = await getStudyBySlug(db, slug);
if (!study) return new Response("Studio non trovato", { status: 404 });

const questionnaires = await listQuestionnaires(db, study.id, { onlyActive: true });
---

<ResearchLayout title={`${study.title} — NexLudica Research`} description={study.description ?? ""}>
  <a href="/" class="text-xs font-semibold uppercase tracking-wider text-nx-gray-dark no-underline hover:text-nx-cyan">
    ← Tutti gli studi
  </a>
  <section class="mt-4">
    <p class="text-sm font-bold uppercase tracking-[0.3em] text-nx-cyan">Studio</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight text-nx-dark sm:text-5xl" style="font-family: var(--font-display);">
      {study.title}
    </h1>
    {study.description && (
      <div class="prose mt-6 max-w-2xl whitespace-pre-line text-nx-gray-dark">
        {study.description}
      </div>
    )}
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold text-nx-dark">Questionari</h2>
    {questionnaires.length === 0 ? (
      <p class="mt-6 rounded-lg border-2 border-dashed border-nx-gray-light/40 bg-white p-8 text-center text-sm text-nx-gray-dark">
        Nessun questionario attivo per questo studio.
      </p>
    ) : (
      <ol class="mt-6 space-y-3">
        {questionnaires.map((q, i) => (
          <li>
            <a
              href={`/research/${study.slug}/${q.slug}`}
              class="flex items-start gap-4 rounded-xl border border-nx-gray-light/20 bg-white p-5 no-underline transition hover:border-nx-cyan hover:shadow-md"
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-nx-cyan text-base font-bold text-white">
                {i + 1}
              </span>
              <div class="flex-1">
                <p class="text-base font-bold text-nx-dark">{q.title}</p>
                {q.description && (
                  <p class="mt-1 text-sm text-nx-gray-dark">{q.description}</p>
                )}
              </div>
              <span class="self-center text-xs font-semibold text-nx-cyan">Inizia →</span>
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</ResearchLayout>
