---
import ResearchLayout from "../../layouts/ResearchLayout.astro";
import { getDb, getEnv } from "../../server/db";
import { listStudies, type Study } from "../../server/research";

export const prerender = false;

const env = await getEnv();
const db = getDb(env as Env);
let studies: Study[] = [];
if (db) {
  try {
    studies = await listStudies(db, { onlyPublic: true, onlyActive: true });
  } catch (e) {
    console.error("[research] listStudies failed", e);
  }
}
---

<ResearchLayout title="NexLudica Research — Studi attivi">
  <section>
    <p class="text-sm font-bold uppercase tracking-[0.3em] text-nx-cyan">Studi di ricerca</p>
    <h1 class="mt-4 text-4xl font-black tracking-tight text-nx-dark sm:text-5xl" style="font-family: var(--font-display);">
      NexLudica Research
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-nx-gray-dark">
      La piattaforma di ricerca di NexLudica APS: questionari psicometrici per studiare
      l'impatto del gioco da tavolo su benessere, dinamiche di gruppo e processi cognitivi.
    </p>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-bold text-nx-dark">Studi attivi</h2>
    {studies.length === 0 ? (
      <p class="mt-6 rounded-lg border-2 border-dashed border-nx-gray-light/40 bg-white p-8 text-center text-sm text-nx-gray-dark">
        Nessuno studio aperto al momento.
      </p>
    ) : (
      <ul class="mt-6 grid gap-4 sm:grid-cols-2">
        {studies.map((s) => (
          <li>
            <a
              href={`/research/${s.slug}`}
              class="block rounded-xl border border-nx-gray-light/20 bg-white p-6 no-underline transition hover:border-nx-cyan hover:shadow-md"
            >
              <p class="text-xs font-bold uppercase tracking-wider text-nx-cyan">Studio attivo</p>
              <h3 class="mt-2 text-lg font-bold text-nx-dark">{s.title}</h3>
              {s.description && (
                <p class="mt-2 line-clamp-3 text-sm text-nx-gray-dark">{s.description}</p>
              )}
              <p class="mt-4 text-xs font-semibold text-nx-cyan">Vai allo studio →</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="mt-16 rounded-xl border border-nx-gray-light/20 bg-white p-6">
    <h2 class="text-lg font-bold text-nx-dark">Sei un partecipante?</h2>
    <p class="mt-2 text-sm text-nx-gray-dark">
      Se hai ricevuto un link diretto via email, aprilo per accedere al questionario
      specifico. Gli studi sono accessibili anche tramite link non listati qui.
    </p>
    <h3 class="mt-6 text-base font-bold text-nx-dark">Come tuteliamo la tua privacy</h3>
    <ul class="mt-2 space-y-1 text-sm text-nx-gray-dark">
      <li>• Non raccogliamo nome, cognome o dati anagrafici espliciti.</li>
      <li>• Per ogni studio puoi avere un codice anonimo generato dai tuoi stessi dati: nessuno (nemmeno NexLudica) puo' risalire alla tua identita'.</li>
      <li>• I dati sono conservati su server europei (Cloudflare D1).</li>
      <li>• Trovi i dettagli completi nella <a href="/privacy-policy" class="text-nx-cyan no-underline hover:underline">privacy policy</a>.</li>
    </ul>
  </section>
</ResearchLayout>
