---
import BaseLayout from "./BaseLayout.astro";
import { getUser } from "../server/guards";

export interface Props {
  title?: string;
  active?: "dashboard" | "profilo" | "articoli" | "verbali" | "admin";
}
const { title = "Area Soci — NexLudica APS", active = "dashboard" } = Astro.props;

const user = await getUser(Astro);
if (!user) {
  return Astro.redirect("/login");
}

const isAdmin = user.role === "admin";

const navItems: Array<{ href: string; key: string; label: string; icon: string; adminOnly?: boolean }> = [
  { href: "/area-soci", key: "dashboard", label: "Dashboard", icon: "▣" },
  { href: "/area-soci/profilo", key: "profilo", label: "Il mio profilo", icon: "◔" },
  { href: "/area-soci/articoli", key: "articoli", label: "Articoli MeetLudica", icon: "✎" },
  { href: "/area-soci/verbali", key: "verbali", label: "Verbali e documenti", icon: "▤" },
  { href: "/area-soci/admin", key: "admin", label: "Amministrazione", icon: "⚙", adminOnly: true },
].filter((it) => !it.adminOnly || isAdmin);
---

<BaseLayout title={title} description="Area riservata ai soci NexLudica.">
  <section class="bg-nx-off-white px-4 pb-8 pt-28">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.3em] text-nx-cyan">Area Soci</p>
          <h1 class="mt-2 text-3xl font-black tracking-tight text-nx-dark sm:text-4xl" style="font-family: var(--font-display);">
            Ciao, {user.name.split(" ")[0]}
          </h1>
        </div>
        <div class="flex items-center gap-3 text-sm text-nx-gray-dark">
          <span>{user.email}</span>
          <a href="/api/auth/logout" class="rounded-md border border-nx-gray-light/40 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-nx-dark no-underline transition hover:border-nx-cyan hover:text-nx-cyan">
            Esci
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-8">
    <div class="grid gap-8 lg:grid-cols-[260px_1fr]">
      <aside class="space-y-1">
        {navItems.map((it) => (
          <a
            href={it.href}
            class={`flex items-center gap-3 rounded-md px-3 py-2.5 text-sm no-underline transition ${
              active === it.key
                ? "bg-nx-cyan-light font-semibold text-nx-cyan"
                : "text-nx-gray-dark hover:bg-nx-off-white hover:text-nx-dark"
            }`}
          >
            <span class={`flex h-7 w-7 items-center justify-center rounded ${
              active === it.key ? "bg-nx-cyan text-white" : "bg-white text-nx-gray-dark"
            } text-sm`}>{it.icon}</span>
            {it.label}
          </a>
        ))}
      </aside>
      <main class="min-w-0">
        <slot />
      </main>
    </div>
  </section>
</BaseLayout>
