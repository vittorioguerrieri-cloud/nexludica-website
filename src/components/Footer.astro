---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-nx-gray-light/30 bg-nx-off-white">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div class="space-y-3">
        <div class="flex items-center gap-3" aria-label="NexLudica">
          <span class="flex flex-col items-center justify-center gap-0.5">
            <img src="/images/branding/die-1.svg" alt="" class="h-3.5 w-auto" loading="lazy" />
            <img src="/images/branding/die-2.svg" alt="" class="h-3.5 w-auto" loading="lazy" />
            <img src="/images/branding/die-3.svg" alt="" class="h-3.5 w-auto" loading="lazy" />
          </span>
          <span class="flex flex-col leading-none">
            <span class="text-2xl font-extrabold tracking-tight">
              <span class="text-nx-cyan">Nex</span><span class="text-nx-dark">Ludica</span>
            </span>
            <span class="mt-1 text-[10px] tracking-[0.2em] text-nx-gray-dark">
              Game | Research | Inclusion
            </span>
          </span>
        </div>
        <p class="text-sm text-nx-gray-dark">
          <span class="font-medium text-nx-dark">NexLudica APS</span><br />
          C.F. 95252550108<br />
          Sede legale: Vico Barnabiti 10, Genova
        </p>
      </div>
      <div class="space-y-2">
        <p class="text-sm font-semibold text-nx-dark">Contatti</p>
        <p class="text-sm text-nx-gray-dark">
          Email:
          <a href="mailto:info@nexludica.org" class="text-nx-cyan no-underline hover:underline">
            info@nexludica.org
          </a>
        </p>
      </div>
      <div class="space-y-2">
        <p class="text-sm font-semibold text-nx-dark">Link utili</p>
        <ul class="space-y-1 text-sm">
          <li>
            <a href="/privacy-policy" class="text-nx-gray-dark hover:text-nx-cyan no-underline hover:underline">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/cookie-policy" class="text-nx-gray-dark hover:text-nx-cyan no-underline hover:underline">
              Cookie Policy
            </a>
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-8 border-t border-nx-gray-light/20 pt-4 text-center text-xs text-nx-gray-light">
      &copy; {year} NexLudica APS &mdash; Tutti i diritti riservati
    </p>
  </div>
</footer>
