---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-nx-gray-light/30 bg-nx-off-white">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div class="space-y-3">
        <img
          src="/images/branding/logo-horizontal.svg"
          alt="NexLudica"
          class="h-14 w-auto"
          loading="lazy"
        />
        <p class="text-sm text-nx-gray-dark">
          <span class="font-medium text-nx-dark">NexLudica APS</span><br />
          C.F. 95252550108<br />
          Sede legale: Vico Barnabiti 10, Genova
        </p>
      </div>
      <div class="space-y-2">
        <p class="text-sm font-semibold text-nx-dark">Contatti</p>
        <p class="text-sm text-nx-gray-dark">
          Email:
          <a href="mailto:info@nexludica.org" class="text-nx-cyan no-underline hover:underline">
            info@nexludica.org
          </a>
        </p>
      </div>
      <div class="space-y-2">
        <p class="text-sm font-semibold text-nx-dark">Link utili</p>
        <ul class="space-y-1 text-sm">
          <li>
            <a href="/privacy-policy" class="text-nx-gray-dark hover:text-nx-cyan no-underline hover:underline">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/cookie-policy" class="text-nx-gray-dark hover:text-nx-cyan no-underline hover:underline">
              Cookie Policy
            </a>
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-8 border-t border-nx-gray-light/20 pt-4 text-center text-xs text-nx-gray-light">
      &copy; {year} NexLudica APS &mdash; Tutti i diritti riservati
    </p>
  </div>
</footer>
