{
	"compatibility_date": "2026-05-05",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "nexludica",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"build": {
		"command": "npm run build"
	},
	"observability": {
		"enabled": true
	}
}
